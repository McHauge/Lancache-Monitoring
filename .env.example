# lancache-monitor environment variables. Copy to .env for local dev.

# HTTP listen address.
LCM_ADDR=:8080

# Theme: mono | teal | gold
LCM_THEME=teal

# Required (recommended). When unset the dashboard runs without auth.
LCM_PASSWORD=lancache

# Path to the lancache nginx access log (mount it into the container).
LCM_LOG_PATH=/data/logs/access.log

# Path to the rate-limit.conf file the monitor reads/writes (mount RW).
LCM_RATELIMIT_PATH=/etc/nginx/conf.d/rate-limit.conf

# SQLite file for per-minute aggregates.
LCM_DB_PATH=/data/monitor.db

# How many days of per-minute history to keep.
LCM_RETENTION_DAYS=30

# Name of the lancache container (used for `docker exec nginx -s reload`).
LCM_LANCACHE_CONTAINER=lancache

# Docker daemon endpoint (mount /var/run/docker.sock to use this default).
LCM_DOCKER_HOST=unix:///var/run/docker.sock

# Optional: persistent session HMAC secret. If empty, one is generated and
# stored next to LCM_DB_PATH so sessions survive container restarts.
# LCM_SESSION_SECRET=
